flowchart TD
    %% Entities
    User[User]

    %% Processes
    P51((5.1\nSelect Content \nto Watch))
    P52((5.2\nVerify \nAccess Rights))
    P53((5.3\nDeliver Stream))
    P54((5.4\nTrack & Update\nProgress))

    %% Data Stores
    D1[(D1: User DB)]
    D2[(D2: Movie DB)]
    D3[(D3: Course DB)]
    D5[(D5: Progress DB)]

    %% Connections
    User -- Click Video/Course --> P51
    P51 -- Content ID + User ID --> P52
    
    P52 -- Fetch Subscriptions --> D1
    P52 -- Access Validated --> P53
    
    P53 -- Request Video URL --> D2
    P53 -- Request Lesson Video --> D3
    P53 -- Stream to Player --> User
    
    User -- Player Events (Pause/Finish) --> P54
    P54 -- Update Completed Modules --> D5
