flowchart TD
    %% Entities
    User[User]
    PG[Razorpay / External Gateway]

    %% Processes
    P41((4.1\nInitiate Checkout))
    P42((4.2\nProcess & \nValidate Payment))
    P43((4.3\nGenerate\nEnrollment))
    P44((4.4\nUpdate User\nSubscription))

    %% Data Stores
    D3[(D3: Course DB)]
    D4[(D4: Payment DB)]
    D1[(D1: User DB)]

    %% Connections
    User -- Request Purchase --> P41
    P41 -- Fetch Amount/Details --> D3
    P41 -- Payment Details --> P42
    
    P42 -- Forward to Gateway --> PG
    PG -- Payment Status/ID --> P42
    
    P42 -- Pass Transaction Info --> P43
    P43 -- Save Payment/Invoice --> D4
    P43 -- Send Enrollment Details --> P44
    
    P44 -- Grant Course Access --> D1
    P44 -- Confirmation/Invoice --> User
