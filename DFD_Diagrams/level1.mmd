flowchart TD
    %% Entities
    User[Student / User]
    Admin[Admin]
    PG[Payment Gateway]

    %% Processes
    P1((1.0\nUser\nAuthentication))
    P2((2.0\nContent\nManagement))
    P3((3.0\nBrowsing &\nSearch))
    P4((4.0\nPayment &\nEnrollment))
    P5((5.0\nStreaming &\nProgress Tracking))
    P6((6.0\nAdmin \nDashboard))

    %% Data Stores
    D1[(D1: User DB)]
    D2[(D2: Movie DB)]
    D3[(D3: Course DB)]
    D4[(D4: Payment & \nEnrollment DB)]
    D5[(D5: Progress & \nVisits DB)]

    %% Connections
    User -- Credentials --> P1
    P1 -- Validation Status --> User
    P1 -- Save/Verify Details --> D1

    Admin -- Upload Details --> P2
    P2 -- Add/Update Movies --> D2
    P2 -- Add/Update Courses --> D3

    User -- Search Queries --> P3
    P3 -- Movie Results --> D2
    P3 -- Course Results --> D3
    P3 -- Display Results --> User

    User -- Select Course / Plan --> P4
    P4 -- Payment Request --> PG
    PG -- Verification --> P4
    P4 -- Save Record --> D4
    P4 -- Update Access --> D1
    P4 -- Receipt --> User

    User -- Play Video --> P5
    P5 -- Check Access --> D1
    P5 -- Fetch Video/Trailer URL --> D2
    P5 -- Fetch Course Modules --> D3
    P5 -- Update User Progress --> D5
    P5 -- Stream Data --> User

    Admin -- Request Stats --> P6
    D5 -- Provide Visit Stats --> P6
    D4 -- Provide Revenue Data --> P6
    P6 -- Show Reports --> Admin
